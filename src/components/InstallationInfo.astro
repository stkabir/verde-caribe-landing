---
const includes = [
	{
		icon: 'sprout',
		title: 'Tierra fertilizada',
		description: 'Sustrato preparado para que el pasto arraigue desde el primer día.',
	},
	{
		icon: 'tools',
		title: 'Mano de obra',
		description: 'Equipo especializado con más de 20 años de experiencia.',
	},
	{
		icon: 'truck',
		title: 'Transporte en Cancún',
		description: 'Entrega y traslado del material sin costo dentro de la ciudad.',
	},
];
---

<div class="bg-surface rounded-3xl p-6 lg:p-10 shadow-soft installation-info" data-reveal="fade">
	<div class="grid lg:grid-cols-2 gap-8 items-center">
		<div class="space-y-5">
			<div>
				<p class="section-eyebrow">¿Qué incluye la instalación?</p>
				<h3 class="text-2xl md:text-3xl font-heading mt-2">
					Todo lo necesario para <em class="text-sage italic">un jardín perfecto</em>
				</h3>
			</div>

			<ul class="space-y-3">
				{includes.map((item) => (
					<li class="flex items-start gap-3">
						<div class="w-9 h-9 rounded-full bg-sage/15 flex items-center justify-center flex-shrink-0 mt-0.5">
							{item.icon === 'sprout' && (
								<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M7 20h10"/>
									<path d="M12 20v-8"/>
									<path d="M12 12c-3 0-5-2-5-5 3 0 5 2 5 5z"/>
									<path d="M12 12c3 0 5-2 5-5-3 0-5 2-5 5z"/>
								</svg>
							)}
							{item.icon === 'tools' && (
								<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
								</svg>
							)}
							{item.icon === 'truck' && (
								<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M1 3h15v13H1z"/>
									<path d="M16 8h4l3 3v5h-7V8z"/>
									<circle cx="5.5" cy="18.5" r="2.5"/>
									<circle cx="18.5" cy="18.5" r="2.5"/>
								</svg>
							)}
						</div>
						<div>
							<p class="font-semibold text-foreground">{item.title}</p>
							<p class="text-sm text-text-secondary">{item.description}</p>
						</div>
					</li>
				))}
			</ul>
		</div>

		<div class="bg-clay/20 border border-border rounded-2xl p-5 lg:p-6 space-y-3">
			<div class="flex items-center gap-2 text-sage">
				<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="12" cy="12" r="10"/>
					<line x1="12" y1="16" x2="12" y2="12"/>
					<line x1="12" y1="8" x2="12.01" y2="8"/>
				</svg>
				<p class="text-sm font-semibold uppercase tracking-wider">Notas importantes</p>
			</div>
			<ul class="space-y-2 text-sm text-text-secondary">
				<li class="flex items-start gap-2">
					<span class="text-sage mt-0.5">•</span>
					<span>La <strong class="text-foreground">tierra para nivelar</strong> se cotiza aparte según las condiciones del terreno.</span>
				</li>
				<li class="flex items-start gap-2">
					<span class="text-sage mt-0.5">•</span>
					<span>El <strong class="text-foreground">transporte fuera de Cancún</strong> tiene un costo adicional desde <strong class="text-foreground">$350</strong>.</span>
				</li>
				<li class="flex items-start gap-2">
					<span class="text-sage mt-0.5">•</span>
					<span>También cotizamos <strong class="text-foreground">plantas, rocas, árboles</strong> y elementos decorativos.</span>
				</li>
			</ul>
		</div>
	</div>
</div>
