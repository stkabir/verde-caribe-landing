---
import { grasses } from '../data/pastos';
import { extras, categoryLabels, categoryOrder } from '../data/extras';

const WA_NUMBER = '529982592189';
---

<div class="bg-surface rounded-3xl shadow-large p-6 lg:p-10 quick-quote" data-quick-quote>
	<div class="grid lg:grid-cols-5 gap-8">
		<form class="space-y-5 lg:col-span-3" data-form>
			<div class="space-y-1">
				<p class="section-eyebrow">Cotización rápida</p>
				<h3 class="text-2xl font-heading">Cuéntanos qué necesitas</h3>
			</div>

			<div class="grid sm:grid-cols-2 gap-4">
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Nombre</span>
					<input type="text" name="name" required placeholder="María González" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Teléfono</span>
					<input type="tel" name="phone" required placeholder="998 123 4567" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
			</div>

			<label class="space-y-1.5 block">
				<span class="text-sm font-semibold text-foreground">Ubicación</span>
				<input type="text" name="location" placeholder="Colonia, ciudad" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
			</label>

			<div class="grid sm:grid-cols-2 gap-4">
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Variedad de pasto</span>
					<select name="grass" required data-grass-select class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input">
						<option value="">Selecciona un pasto</option>
						{grasses.map((g) => (
							<option value={g.slug} data-sin={g.priceSin} data-con={g.priceCon}>{g.name}</option>
						))}
					</select>
				</label>
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Área (m²)</span>
					<input type="number" name="m2" min="1" placeholder="50" data-m2 class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
			</div>

			<div class="flex flex-wrap items-center gap-6 py-2">
				<label class="flex items-center gap-3 cursor-pointer">
					<input type="checkbox" name="install" data-install class="w-5 h-5 accent-[#8C9A84]"/>
					<span class="text-sm font-medium">¿Requiere instalación?</span>
				</label>
				<label class="flex items-center gap-3 cursor-pointer">
					<input type="checkbox" name="outside" data-outside class="w-5 h-5 accent-[#8C9A84]"/>
					<span class="text-sm font-medium">Fuera de Cancún</span>
				</label>
			</div>

			<p class="text-xs text-text-secondary -mt-2 install-note" hidden>
				<span class="inline-flex items-center gap-1.5 text-sage">
					<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					Incluye tierra fertilizada, mano de obra y transporte en Cancún.
				</span>
			</p>
			<p class="text-xs text-text-secondary -mt-2 outside-note" hidden>
				<span class="inline-flex items-center gap-1.5 text-terracotta">
					<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					Se agregará transporte desde $350 según la distancia.
				</span>
			</p>

			<div class="space-y-2">
				<p class="text-sm font-semibold text-foreground">Extras (opcional)</p>
				<div class="space-y-4" data-extras>
					{categoryOrder.map((cat) => {
						const items = extras.filter((e) => e.category === cat);
						return (
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-wider text-sage font-semibold">{categoryLabels[cat]}</p>
								<div class="flex flex-wrap gap-2">
									{items.map((item) => (
										<label class="extra-chip" data-extra={item.slug} data-price={item.price} data-name={item.name} data-unit={item.unit}>
											<input type="checkbox" class="sr-only" data-extra-input/>
											<span class="extra-chip-content">
												<span class="extra-name">{item.name}</span>
												<span class="extra-price">${item.price.toLocaleString('es-MX')} / {item.unit}</span>
											</span>
										</label>
									))}
								</div>
							</div>
						);
					})}
				</div>
			</div>

			<label class="space-y-1.5 block">
				<span class="text-sm font-semibold text-foreground">Notas (opcional)</span>
				<textarea name="notes" rows="2" placeholder="Detalles adicionales, fecha deseada, etc." class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none form-input"></textarea>
			</label>

			<button type="button" data-send class="btn btn-primary w-full sm:w-auto">
				<svg class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 4.9L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
				Enviar a WhatsApp
			</button>
		</form>

		<aside class="lg:col-span-2 estimate-aside" data-estimate>
			<div class="estimate-box">
				<div class="flex items-center justify-between mb-4">
					<h4 class="font-heading text-lg">Estimado en vivo</h4>
					<span class="text-xs text-text-secondary">MXN</span>
				</div>

				<div class="space-y-3 text-sm estimate-lines">
					<div class="estimate-line estimate-grass hidden">
						<span class="estimate-label" data-grass-label>Pasto</span>
						<span class="estimate-value" data-grass-value>$0</span>
					</div>
					<div class="estimate-line estimate-extras hidden">
						<span class="estimate-label">Extras (<span data-extras-count>0</span>)</span>
						<button type="button" class="estimate-toggle text-xs text-sage hover:underline" data-toggle-extras>Ver detalle</button>
						<span class="estimate-value" data-extras-value>$0</span>
					</div>
					<div class="estimate-extras-detail hidden" data-extras-detail></div>
					<div class="estimate-line estimate-outside hidden">
						<span class="estimate-label">Transporte fuera de Cancún</span>
						<span class="estimate-value">desde $350</span>
					</div>
				</div>

				<div class="estimate-divider"></div>

				<div class="estimate-total">
					<span class="estimate-total-label">Total estimado</span>
					<span class="estimate-total-value" data-total>$0</span>
				</div>
				<p class="estimate-disclaimer">
					Precio referencial, sujeto a visita técnica y disponibilidad.
				</p>
			</div>
		</aside>
	</div>
</div>

<style>
	.quick-quote {
		position: relative;
	}

	.extra-chip {
		cursor: pointer;
		user-select: none;
	}

	.extra-chip-content {
		display: inline-flex;
		flex-direction: column;
		gap: 2px;
		padding: 0.5rem 0.875rem;
		border-radius: 9999px;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		font-size: 0.85rem;
		transition: all 0.2s ease-out;
	}

	.extra-name {
		font-weight: 600;
		color: var(--color-foreground);
	}

	.extra-price {
		font-size: 0.7rem;
		color: var(--color-text-secondary);
	}

	.extra-chip:has(input:checked) .extra-chip-content {
		background: var(--color-sage);
		border-color: var(--color-sage);
		color: white;
	}

	.extra-chip:has(input:checked) .extra-name,
	.extra-chip:has(input:checked) .extra-price {
		color: white;
	}

	.extra-chip:hover .extra-chip-content {
		border-color: var(--color-sage);
		transform: translateY(-1px);
	}

	.estimate-aside {
		position: sticky;
		top: 100px;
		align-self: start;
	}

	.estimate-box {
		background: linear-gradient(135deg, var(--color-clay) 0%, #e8e0d4 100%);
		border-radius: 1.5rem;
		padding: 1.75rem;
		box-shadow: var(--shadow-soft);
	}

	.estimate-line {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.estimate-label {
		color: var(--color-text-secondary);
	}

	.estimate-value {
		font-weight: 600;
		font-family: var(--font-heading);
		color: var(--color-forest);
	}

	.estimate-divider {
		height: 1px;
		background: rgba(45, 58, 49, 0.1);
		margin: 1rem 0;
	}

	.estimate-total {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.estimate-total-label {
		font-weight: 600;
		color: var(--color-foreground);
	}

	.estimate-total-value {
		font-family: var(--font-heading);
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--color-forest);
	}

	.estimate-disclaimer {
		font-size: 0.7rem;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.estimate-extras-detail {
		background: rgba(255, 255, 255, 0.5);
		border-radius: 0.75rem;
		padding: 0.5rem 0.75rem;
		margin-top: 0.5rem;
		font-size: 0.8rem;
	}

	.estimate-extras-detail .extra-row {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 2px 0;
		color: var(--color-text-secondary);
	}

	.estimate-extras-detail .extra-row span:last-child {
		font-weight: 600;
		color: var(--color-foreground);
	}

	@media (max-width: 1023px) {
		.estimate-aside {
			position: static;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.extra-chip-content {
			transition: none !important;
		}
	}
</style>

<script define:vars={{ WA_NUMBER }}>
	const form = document.querySelector('[data-quick-quote] [data-form]');
	if (form) {
		const grassSelect = form.querySelector('[data-grass-select]');
		const m2Input = form.querySelector('[data-m2]');
		const installCheck = form.querySelector('[data-install]');
		const outsideCheck = form.querySelector('[data-outside]');
		const installNote = form.querySelector('.install-note');
		const outsideNote = form.querySelector('.outside-note');
		const extrasContainer = form.querySelector('[data-extras]');
		const sendBtn = form.querySelector('[data-send]');
		const aside = document.querySelector('[data-quick-quote] [data-estimate]');

		const fmt = (n) => '$' + Math.round(n).toLocaleString('es-MX');

		const updateEstimate = () => {
			const grassSlug = grassSelect.value;
			const m2 = parseFloat(m2Input.value) || 0;
			const withInstall = installCheck.checked;
			const outside = outsideCheck.checked;

			const grassLine = aside.querySelector('.estimate-grass');
			const grassLabel = aside.querySelector('[data-grass-label]');
			const grassValue = aside.querySelector('[data-grass-value]');
			const extrasLine = aside.querySelector('.estimate-extras');
			const extrasCountEl = aside.querySelector('[data-extras-count]');
			const extrasValueEl = aside.querySelector('[data-extras-value]');
			const extrasDetailEl = aside.querySelector('[data-extras-detail]');
			const outsideLine = aside.querySelector('.estimate-outside');
			const totalEl = aside.querySelector('[data-total]');

			let grassTotal = 0;
			let pricePerM2 = 0;
			let grassName = '';

			if (grassSlug) {
				const opt = grassSelect.querySelector(`option[value="${grassSlug}"]`);
				pricePerM2 = parseFloat(opt.dataset[withInstall ? 'con' : 'sin']) || 0;
				grassName = opt.textContent;
				grassTotal = m2 * pricePerM2;
			}

			if (grassTotal > 0) {
				grassLine.classList.remove('hidden');
				grassLabel.textContent = `${grassName} (${m2} m²${withInstall ? ' c/instalación' : ''})`;
				grassValue.textContent = fmt(grassTotal);
			} else {
				grassLine.classList.add('hidden');
			}

			const checkedExtras = extrasContainer.querySelectorAll('input[data-extra-input]:checked');
			const extrasArr = [];
			checkedExtras.forEach((inp) => {
				const chip = inp.closest('[data-extra]');
				extrasArr.push({
					name: chip.dataset.name,
					price: parseFloat(chip.dataset.price),
				});
			});

			const extrasTotal = extrasArr.reduce((s, e) => s + e.price, 0);

			if (extrasTotal > 0) {
				extrasLine.classList.remove('hidden');
				extrasCountEl.textContent = extrasArr.length;
				extrasValueEl.textContent = fmt(extrasTotal);
				extrasDetailEl.innerHTML = extrasArr.map((e) => `
					<div class="extra-row"><span>${e.name}</span><span>${fmt(e.price)}</span></div>
				`).join('');
			} else {
				extrasLine.classList.add('hidden');
				extrasDetailEl.classList.add('hidden');
				extrasDetailEl.innerHTML = '';
			}

			if (outside && (grassTotal > 0 || extrasTotal > 0)) {
				outsideLine.classList.remove('hidden');
			} else {
				outsideLine.classList.add('hidden');
			}

			const total = grassTotal + extrasTotal;
			totalEl.textContent = total > 0 ? fmt(total) : '$0';
		};

		const toggleNote = (note, show) => {
			if (!note) return;
			note.hidden = !show;
		};

		[grassSelect, m2Input, installCheck, outsideCheck].forEach((el) => {
			el.addEventListener('input', updateEstimate);
			el.addEventListener('change', updateEstimate);
		});

		installCheck.addEventListener('change', () => toggleNote(installNote, installCheck.checked));
		outsideCheck.addEventListener('change', () => toggleNote(outsideNote, outsideCheck.checked));

		form.addEventListener('change', (e) => {
			if (e.target.matches('input[data-extra-input]')) updateEstimate();
		});

		const toggleBtn = aside.querySelector('[data-toggle-extras]');
		const detailEl = aside.querySelector('[data-extras-detail]');
		toggleBtn?.addEventListener('click', () => {
			detailEl.classList.toggle('hidden');
			toggleBtn.textContent = detailEl.classList.contains('hidden') ? 'Ver detalle' : 'Ocultar';
		});

		sendBtn?.addEventListener('click', () => {
			const fd = new FormData(form);
			const name = (fd.get('name') || '').toString().trim();
			const phone = (fd.get('phone') || '').toString().trim();
			const location = (fd.get('location') || '').toString().trim();
			const grassSlug = fd.get('grass') || '';
			const m2 = parseFloat(fd.get('m2') || '0') || 0;
			const install = fd.get('install') === 'on';
			const outside = fd.get('outside') === 'on';
			const notes = (fd.get('notes') || '').toString().trim();

			if (!name || !phone || !grassSlug || m2 <= 0) {
				alert('Por favor completa nombre, teléfono, variedad y área.');
				return;
			}

			const opt = grassSelect.querySelector(`option[value="${grassSlug}"]`);
			const grassName = opt ? opt.textContent : grassSlug;
			const pricePerM2 = parseFloat(opt.dataset[install ? 'con' : 'sin']) || 0;
			const grassSub = m2 * pricePerM2;

			const checkedExtras = extrasContainer.querySelectorAll('input[data-extra-input]:checked');
			const extrasArr = [];
			checkedExtras.forEach((inp) => {
				const chip = inp.closest('[data-extra]');
				extrasArr.push({ name: chip.dataset.name, price: parseFloat(chip.dataset.price), unit: chip.dataset.unit });
			});
			const extrasTotal = extrasArr.reduce((s, e) => s + e.price, 0);
			const total = grassSub + extrasTotal;

			const lines = [
				'🌿 *Cotización Verde Caribe*',
				'',
				`👤 *Nombre:* ${name}`,
				`📞 *Teléfono:* ${phone}`,
			];
			if (location) lines.push(`📍 *Ubicación:* ${location}`);
			lines.push(
				'',
				`🌱 *Variedad:* ${grassName}`,
				`📐 *Área:* ${m2} m²`,
				`🔧 *Instalación:* ${install ? 'Sí' : 'No'}`,
			);
			if (install) {
				lines.push('   _(incluye tierra fertilizada, mano de obra y transporte en Cancún)_');
			}
			if (outside) {
				lines.push('🚚 *Zona:* Fuera de Cancún _(transporte desde $350)_');
			}
			if (extrasArr.length > 0) {
				lines.push('', '🎁 *Extras:*');
				extrasArr.forEach((e) => {
					lines.push(`   • ${e.name} — ${fmt(e.price)} / ${e.unit}`);
				});
			}
			lines.push('', `💰 *Estimado:* ${fmt(total)} MXN`, '_(precio referencial, sujeto a visita técnica)_');
			if (notes) {
				lines.push('', `📝 *Notas:* ${notes}`);
			}

			const msg = encodeURIComponent(lines.join('\n'));
			window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank');
		});
	}
</script>
