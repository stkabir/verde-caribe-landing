---
const WA_NUMBER = '529982592189';

const spaceTypes = [
	{ id: 'residencial', name: 'Residencial', description: 'Casa, jardín familiar, terraza' },
	{ id: 'comercial', name: 'Comercial', description: 'Local, restaurante, oficina' },
	{ id: 'hotelero', name: 'Hotelero', description: 'Hotel, resort, área común' },
	{ id: 'eventual', name: 'Evento', description: 'Boda, evento temporal' },
];

const sizes = [
	{ id: 's', label: 'Hasta 50 m²' },
	{ id: 'm', label: '50 - 150 m²' },
	{ id: 'l', label: '150 - 500 m²' },
	{ id: 'xl', label: '500 - 1500 m²' },
	{ id: 'xxl', label: 'Más de 1500 m²' },
];

const styles = [
	{ id: 'tropical', name: 'Tropical', description: 'Palmeras, colores vivos, exuberante' },
	{ id: 'minimalista', name: 'Minimalista', description: 'Líneas limpias, grava, pocos elementos' },
	{ id: 'familiar', name: 'Familiar', description: 'Pasto, juegos, áreas verdes abiertas' },
	{ id: 'corporativo', name: 'Corporativo', description: 'Ordenado, geométrico, de bajo mantenimiento' },
];

const elements = [
	{ id: 'plantas', name: 'Plantas', description: 'Arbustos, florales, suculentas' },
	{ id: 'arboles', name: 'Árboles', description: 'Frutales, ornamentales, sombra' },
	{ id: 'rocas', name: 'Rocas y piedras', description: 'Decorativas, caminos, muros' },
	{ id: 'agua', name: 'Agua', description: 'Fuentes, espejos, estanques' },
	{ id: 'luz', name: 'Iluminación', description: 'Ambiental, decorativa, funcional' },
	{ id: 'caminos', name: 'Caminos', description: 'Adoquín, piedra, madera' },
];

const services = [
	{ id: 'mantenimiento', name: 'Mantenimiento mensual' },
	{ id: 'riego', name: 'Riego automático' },
	{ id: 'diseno', name: 'Diseño profesional' },
	{ id: 'tierra', name: 'Tierra para nivelar' },
];
---

<div class="bg-surface rounded-3xl shadow-large p-6 lg:p-10 garden-wizard" data-wizard>
	<div class="wizard-header flex items-center justify-between mb-6">
		<div>
			<p class="section-eyebrow">Diseño guiado</p>
			<h3 class="text-2xl font-heading">Diseña tu jardín</h3>
		</div>
		<button type="button" class="wizard-clear" data-wizard-clear aria-label="Limpiar selección">
			<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
				<polyline points="3 6 5 6 21 6"/>
				<path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
				<path d="M10 11v6M14 11v6"/>
				<path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
			</svg>
		</button>
	</div>

	<div class="wizard-progress mb-8">
		<div class="wizard-progress-bar" data-progress-bar></div>
		<div class="wizard-progress-labels">
			<span data-progress-text>Paso 1 de 6</span>
			<span data-progress-percent>0%</span>
		</div>
	</div>

	<div class="wizard-body" data-wizard-body>
		<!-- Paso 1: Tipo de espacio -->
		<div class="wizard-step" data-step="1">
			<h4 class="wizard-step-title">¿Qué tipo de espacio vas a diseñar?</h4>
			<div class="wizard-grid wizard-grid-4">
				{spaceTypes.map((s) => (
					<button type="button" class="wizard-option" data-option="space" data-value={s.id} data-name={s.name}>
						<span class="wizard-option-name">{s.name}</span>
						<span class="wizard-option-desc">{s.description}</span>
					</button>
				))}
			</div>
		</div>

		<!-- Paso 2: Tamaño -->
		<div class="wizard-step" data-step="2" hidden>
			<h4 class="wizard-step-title">¿De qué tamaño es el área?</h4>
			<div class="wizard-grid wizard-grid-5">
				{sizes.map((s) => (
					<button type="button" class="wizard-option" data-option="size" data-value={s.id} data-name={s.label}>
						<span class="wizard-option-name">{s.label}</span>
					</button>
				))}
			</div>
		</div>

		<!-- Paso 3: Estilo (íconos por ahora) -->
		<div class="wizard-step" data-step="3" hidden>
			<h4 class="wizard-step-title">¿Qué estilo te gustaría?</h4>
			<div class="wizard-grid wizard-grid-4">
				{styles.map((s) => (
					<button type="button" class="wizard-option wizard-option-icon" data-option="style" data-value={s.id} data-name={s.name}>
						<span class="wizard-option-icon-wrap" aria-hidden="true">
							{s.id === 'tropical' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M12 22V8"/>
									<path d="M12 8c-3-1-5-4-5-8 3 0 5 3 5 8z"/>
									<path d="M12 8c3-1 5-4 5-8-3 0-5 3-5 8z"/>
									<path d="M12 14c-2-1-4-3-4-6 2 0 4 2 4 6z"/>
									<path d="M12 14c2-1 4-3 4-6-2 0-4 2-4 6z"/>
								</svg>
							)}
							{s.id === 'minimalista' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<rect x="3" y="3" width="18" height="18" rx="1"/>
									<line x1="3" y1="12" x2="21" y2="12"/>
									<circle cx="7" cy="7" r="1" fill="currentColor"/>
								</svg>
							)}
							{s.id === 'familiar' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M3 11l9-7 9 7v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-9z"/>
									<path d="M9 22V12h6v10"/>
								</svg>
							)}
							{s.id === 'corporativo' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<rect x="3" y="3" width="7" height="18"/>
									<rect x="14" y="8" width="7" height="13"/>
									<line x1="6" y1="7" x2="6" y2="7"/>
									<line x1="6" y1="11" x2="6" y2="11"/>
									<line x1="6" y1="15" x2="6" y2="15"/>
									<line x1="17" y1="12" x2="17" y2="12"/>
									<line x1="17" y1="16" x2="17" y2="16"/>
								</svg>
							)}
						</span>
						<!-- TODO: reemplazar íconos por imágenes reales -->
						<span class="wizard-option-name">{s.name}</span>
						<span class="wizard-option-desc">{s.description}</span>
					</button>
				))}
			</div>
		</div>

		<!-- Paso 4: Elementos -->
		<div class="wizard-step" data-step="4" hidden>
			<h4 class="wizard-step-title">¿Qué elementos quieres incluir?</h4>
			<p class="wizard-step-sub">Selecciona todos los que apliquen</p>
			<div class="wizard-grid wizard-grid-3">
				{elements.map((e) => (
					<label class="wizard-multi">
						<input type="checkbox" data-multi="elements" data-value={e.id} data-name={e.name}/>
						<span class="wizard-multi-content">
							<span class="wizard-multi-name">{e.name}</span>
							<span class="wizard-multi-desc">{e.description}</span>
						</span>
						<span class="wizard-multi-check" aria-hidden="true">
							<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
						</span>
					</label>
				))}
			</div>
		</div>

		<!-- Paso 5: Servicios extra -->
		<div class="wizard-step" data-step="5" hidden>
			<h4 class="wizard-step-title">¿Necesitas servicios adicionales?</h4>
			<p class="wizard-step-sub">Opcional, puedes dejarlo en blanco</p>
			<div class="wizard-grid wizard-grid-2">
				{services.map((s) => (
					<label class="wizard-multi">
						<input type="checkbox" data-multi="services" data-value={s.id} data-name={s.name}/>
						<span class="wizard-multi-content">
							<span class="wizard-multi-name">{s.name}</span>
						</span>
						<span class="wizard-multi-check" aria-hidden="true">
							<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
						</span>
					</label>
				))}
			</div>
		</div>

		<!-- Paso 6: Contacto + Resumen -->
		<div class="wizard-step" data-step="6" hidden>
			<h4 class="wizard-step-title">Tus datos y resumen</h4>
			<div class="wizard-grid wizard-grid-2-col">
				<div class="wizard-form space-y-4">
					<label class="space-y-1.5 block">
						<span class="text-sm font-semibold text-foreground">Nombre</span>
						<input type="text" data-field="name" required placeholder="Tu nombre" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
					</label>
					<label class="space-y-1.5 block">
						<span class="text-sm font-semibold text-foreground">Teléfono</span>
						<input type="tel" data-field="phone" required placeholder="998 123 4567" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
					</label>
					<label class="space-y-1.5 block">
						<span class="text-sm font-semibold text-foreground">Ubicación</span>
						<input type="text" data-field="location" placeholder="Colonia, ciudad" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
					</label>
					<label class="space-y-1.5 block">
						<span class="text-sm font-semibold text-foreground">Notas (opcional)</span>
						<textarea data-field="notes" rows="2" placeholder="Detalles adicionales" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none form-input"></textarea>
					</label>
				</div>
				<div class="wizard-summary" data-summary>
					<h5 class="wizard-summary-title">Tu diseño</h5>
					<div class="wizard-summary-body" data-summary-body></div>
				</div>
			</div>
		</div>
	</div>

	<div class="wizard-nav mt-8 flex items-center justify-between gap-4">
		<button type="button" class="wizard-btn wizard-btn-back" data-wizard-prev disabled>
			<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
			Atrás
		</button>
		<button type="button" class="wizard-btn wizard-btn-next btn-primary-style" data-wizard-next>
			Siguiente
		</button>
		<button type="button" class="wizard-btn wizard-btn-send btn-primary-style" data-wizard-send hidden>
			<svg class="w-4 h-4 mr-1.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 4.9L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
			Enviar a WhatsApp
		</button>
	</div>
</div>

<style>
	.wizard-progress {
		position: relative;
	}

	.wizard-progress-bar {
		height: 6px;
		background: var(--color-sage);
		border-radius: 9999px;
		width: 0;
		transition: width 0.4s ease-out;
	}

	.wizard-progress::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 6px;
		background: var(--color-border);
		border-radius: 9999px;
		z-index: -1;
	}

	.wizard-progress-labels {
		display: flex;
		justify-content: space-between;
		margin-top: 0.5rem;
		font-size: 0.8rem;
		color: var(--color-text-secondary);
	}

	.wizard-clear {
		width: 40px;
		height: 40px;
		border-radius: 9999px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		transition: all 0.2s ease-out;
		cursor: pointer;
	}

	.wizard-clear:hover {
		color: white;
		background: var(--color-terracotta);
		border-color: var(--color-terracotta);
		transform: translateY(-1px);
	}

	.wizard-step {
		animation: stepFade 0.4s ease-out;
	}

	@keyframes stepFade {
		from { opacity: 0; transform: translateX(20px); }
		to { opacity: 1; transform: translateX(0); }
	}

	.wizard-step-title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.wizard-step-sub {
		color: var(--color-text-secondary);
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}

	.wizard-grid {
		display: grid;
		gap: 0.75rem;
	}

	.wizard-grid-2 { grid-template-columns: 1fr; }
	.wizard-grid-2-col { grid-template-columns: 1fr; }
	.wizard-grid-3 { grid-template-columns: 1fr; }
	.wizard-grid-4 { grid-template-columns: 1fr 1fr; }
	.wizard-grid-5 { grid-template-columns: 1fr 1fr; }

	@media (min-width: 640px) {
		.wizard-grid-3 { grid-template-columns: 1fr 1fr; }
		.wizard-grid-4 { grid-template-columns: 1fr 1fr; }
		.wizard-grid-5 { grid-template-columns: 1fr 1fr 1fr; }
		.wizard-grid-2-col { grid-template-columns: 1fr 1fr; }
	}

	@media (min-width: 768px) {
		.wizard-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
		.wizard-grid-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
		.wizard-grid-5 { grid-template-columns: repeat(5, 1fr); }
	}

	.wizard-option {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.4rem;
		padding: 1.25rem;
		border-radius: 1rem;
		border: 2px solid var(--color-border);
		background: var(--color-surface);
		text-align: left;
		cursor: pointer;
		transition: all 0.2s ease-out;
		min-height: 90px;
	}

	.wizard-option:hover {
		border-color: var(--color-sage);
		transform: translateY(-2px);
	}

	.wizard-option.is-selected {
		border-color: var(--color-sage);
		background: rgba(140, 154, 132, 0.1);
	}

	.wizard-option-name {
		font-weight: 600;
		color: var(--color-foreground);
	}

	.wizard-option-desc {
		font-size: 0.8rem;
		color: var(--color-text-secondary);
	}

	.wizard-option-icon {
		align-items: center;
		text-align: center;
		padding: 1.5rem 1rem;
	}

	.wizard-option-icon .wizard-option-icon-wrap {
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-sage);
	}

	.wizard-option-icon .wizard-option-icon-wrap svg {
		width: 100%;
		height: 100%;
	}

	.wizard-multi {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 1.25rem;
		border-radius: 1rem;
		border: 2px solid var(--color-border);
		background: var(--color-surface);
		cursor: pointer;
		transition: all 0.2s ease-out;
		position: relative;
	}

	.wizard-multi:hover {
		border-color: var(--color-sage);
	}

	.wizard-multi:has(input:checked) {
		border-color: var(--color-sage);
		background: rgba(140, 154, 132, 0.1);
	}

	.wizard-multi-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.wizard-multi-name {
		font-weight: 600;
	}

	.wizard-multi-desc {
		font-size: 0.8rem;
		color: var(--color-text-secondary);
	}

	.wizard-multi-check {
		width: 22px;
		height: 22px;
		border-radius: 9999px;
		border: 2px solid var(--color-border);
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		background: var(--color-surface);
		transition: all 0.2s ease-out;
		flex-shrink: 0;
	}

	.wizard-multi:has(input:checked) .wizard-multi-check {
		background: var(--color-sage);
		border-color: var(--color-sage);
	}

	.wizard-summary {
		background: var(--color-clay);
		border-radius: 1rem;
		padding: 1.25rem;
	}

	.wizard-summary-title {
		font-family: var(--font-heading);
		font-size: 1.1rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
	}

	.wizard-summary-body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.summary-row {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.4rem 0;
		border-bottom: 1px solid rgba(45, 58, 49, 0.1);
		font-size: 0.85rem;
	}

	.summary-row:last-child {
		border-bottom: none;
	}

	.summary-label {
		color: var(--color-text-secondary);
		font-weight: 500;
	}

	.summary-value {
		font-weight: 600;
		text-align: right;
		max-width: 60%;
	}

	.wizard-nav {
		display: flex;
		gap: 0.75rem;
	}

	.wizard-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.75rem 1.5rem;
		border-radius: 9999px;
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		transition: all 0.2s ease-out;
		border: none;
	}

	.wizard-btn-back {
		background: transparent;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
	}

	.wizard-btn-back:hover:not(:disabled) {
		color: var(--color-foreground);
		border-color: var(--color-foreground);
	}

	.wizard-btn-back:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.btn-primary-style {
		background: var(--color-forest);
		color: white;
		box-shadow: 0 10px 25px rgba(45, 58, 49, 0.15);
	}

	.btn-primary-style:hover:not(:disabled) {
		background: var(--color-terracotta);
		transform: translateY(-2px);
	}

	.btn-primary-style:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.wizard-btn-send {
		margin-left: auto;
	}

	@media (prefers-reduced-motion: reduce) {
		.wizard-progress-bar,
		.wizard-step,
		.wizard-option,
		.wizard-multi {
			transition: none !important;
			animation: none !important;
		}
	}
</style>

<script define:vars={{ WA_NUMBER }}>
	const root = document.querySelector('[data-wizard]');
	if (root) {
		const state = {
			step: 1,
			totalSteps: 6,
			selections: {
				space: null,
				size: null,
				style: null,
				elements: [],
				services: [],
				name: '',
				phone: '',
				location: '',
				notes: '',
			},
		};

		const STORAGE_KEY = 'verde-caribe-wizard';

		const load = () => {
			try {
				const saved = localStorage.getItem(STORAGE_KEY);
				if (saved) {
					const data = JSON.parse(saved);
					Object.assign(state.selections, data.selections || {});
					state.step = data.step || 1;
				}
			} catch (e) { /* noop */ }
		};

		const save = () => {
			try {
				localStorage.setItem(STORAGE_KEY, JSON.stringify({ step: state.step, selections: state.selections }));
			} catch (e) { /* noop */ }
		};

		const reset = () => {
			try { localStorage.removeItem(STORAGE_KEY); } catch (e) { /* noop */ }
			state.step = 1;
			state.selections = {
				space: null,
				size: null,
				style: null,
				elements: [],
				services: [],
				name: '',
				phone: '',
				location: '',
				notes: '',
			};
			render();
		};

		const render = () => {
			root.querySelectorAll('[data-step]').forEach((s) => {
				const n = parseInt(s.dataset.step, 10);
				s.hidden = n !== state.step;
			});

			const percent = Math.round((state.step / state.totalSteps) * 100);
			root.querySelector('[data-progress-bar]').style.width = percent + '%';
			root.querySelector('[data-progress-text]').textContent = `Paso ${state.step} de ${state.totalSteps}`;
			root.querySelector('[data-progress-percent]').textContent = percent + '%';

			root.querySelectorAll('[data-option]').forEach((opt) => {
				const key = opt.dataset.option;
				const val = opt.dataset.value;
				const selected = state.selections[key] === val;
				opt.classList.toggle('is-selected', selected);
			});

			root.querySelectorAll('[data-multi]').forEach((cb) => {
				const key = cb.dataset.multi;
				const val = cb.dataset.value;
				cb.checked = state.selections[key].includes(val);
			});

			root.querySelectorAll('[data-field]').forEach((f) => {
				const key = f.dataset.field;
				if (f.value !== (state.selections[key] || '')) f.value = state.selections[key] || '';
			});

			const prev = root.querySelector('[data-wizard-prev]');
			const next = root.querySelector('[data-wizard-next]');
			const send = root.querySelector('[data-wizard-send]');
			prev.disabled = state.step === 1;
			if (state.step === state.totalSteps) {
				next.hidden = true;
				send.hidden = false;
				renderSummary();
			} else {
				next.hidden = false;
				send.hidden = true;
				next.disabled = !isStepValid();
			}
		};

		const isStepValid = () => {
			switch (state.step) {
				case 1: return !!state.selections.space;
				case 2: return !!state.selections.size;
				case 3: return !!state.selections.style;
				case 4: return true;
				case 5: return true;
				case 6: return !!(state.selections.name && state.selections.phone);
				default: return false;
			}
		};

		const renderSummary = () => {
			const body = root.querySelector('[data-summary-body]');
			const s = state.selections;
			const rows = [];
			if (s.space) rows.push(['Espacio', findName('space', s.space)]);
			if (s.size) rows.push(['Tamaño', findName('size', s.size)]);
			if (s.style) rows.push(['Estilo', findName('style', s.style)]);
			if (s.elements.length) rows.push(['Elementos', s.elements.map((v) => findName('elements', v)).join(', ')]);
			if (s.services.length) rows.push(['Servicios', s.services.map((v) => findName('services', v)).join(', ')]);
			body.innerHTML = rows.map(([l, v]) => `
				<div class="summary-row"><span class="summary-label">${l}</span><span class="summary-value">${v}</span></div>
			`).join('') || '<p class="text-sm text-text-secondary">Sin selecciones aún</p>';
		};

		const findName = (group, value) => {
			const el = root.querySelector(`[data-option="${group}"][data-value="${value}"], [data-multi="${group}"][data-value="${value}"]`);
			return el ? el.dataset.name : value;
		};

		load();
		render();

		root.addEventListener('click', (e) => {
			const opt = e.target.closest('[data-option]');
			if (opt) {
				state.selections[opt.dataset.option] = opt.dataset.value;
				save();
				render();
				return;
			}
			if (e.target.closest('[data-wizard-next]')) {
				if (isStepValid()) {
					state.step = Math.min(state.totalSteps, state.step + 1);
					save();
					render();
				}
			}
			if (e.target.closest('[data-wizard-prev]')) {
				state.step = Math.max(1, state.step - 1);
				save();
				render();
			}
			if (e.target.closest('[data-wizard-clear]')) {
				if (confirm('¿Limpiar todas las selecciones del diseño?')) {
					reset();
				}
			}
		});

		root.addEventListener('change', (e) => {
			const cb = e.target.closest('[data-multi]');
			if (cb) {
				const arr = state.selections[cb.dataset.multi];
				if (cb.checked && !arr.includes(cb.dataset.value)) arr.push(cb.dataset.value);
				if (!cb.checked) state.selections[cb.dataset.multi] = arr.filter((v) => v !== cb.dataset.value);
				save();
				render();
			}
		});

		root.addEventListener('input', (e) => {
			const f = e.target.closest('[data-field]');
			if (f) {
				state.selections[f.dataset.field] = f.value;
				save();
				if (state.step === state.totalSteps) {
					render();
				}
			}
		});

		root.addEventListener('click', (e) => {
			if (e.target.closest('[data-wizard-send]')) {
				if (!state.selections.name || !state.selections.phone) {
					alert('Por favor completa nombre y teléfono.');
					return;
				}
				const s = state.selections;
				const lines = [
					'🌿 *Diseño de jardín Verde Caribe*',
					'',
					`👤 *Nombre:* ${s.name}`,
					`📞 *Teléfono:* ${s.phone}`,
				];
				if (s.location) lines.push(`📍 *Ubicación:* ${s.location}`);
				lines.push('', '🎨 *Mi diseño:*');
				if (s.space) lines.push(`   • Tipo: ${findName('space', s.space)}`);
				if (s.size) lines.push(`   • Tamaño: ${findName('size', s.size)}`);
				if (s.style) lines.push(`   • Estilo: ${findName('style', s.style)}`);
				if (s.elements.length) lines.push(`   • Elementos: ${s.elements.map((v) => findName('elements', v)).join(', ')}`);
				if (s.services.length) lines.push(`   • Servicios: ${s.services.map((v) => findName('services', v)).join(', ')}`);
				if (s.notes) lines.push('', `📝 *Notas:* ${s.notes}`);
				const msg = encodeURIComponent(lines.join('\n'));
				window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank');
			}
		});
	}
</script>
