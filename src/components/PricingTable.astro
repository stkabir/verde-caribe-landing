---
import { grasses } from '../data/pastos';
import InstallationInfo from './InstallationInfo.astro';
---

<div class="space-y-12 pricing-section" data-reveal="fade">
	<header class="text-center max-w-2xl mx-auto space-y-4 section-header">
		<p class="section-eyebrow">Precios transparentes</p>
		<h2 class="text-3xl md:text-4xl font-heading section-title">
			Pasto fresco, <em class="text-sage italic">precio claro</em>
		</h2>
		<p class="text-text-secondary section-desc">
			Precios por metro cuadrado. La instalación incluye tierra fertilizada, mano de obra
			y transporte dentro de Cancún.
		</p>
	</header>

	<div class="grid md:grid-cols-3 gap-6 lg:gap-8 pricing-grid" data-scroll="card">
		{grasses.map((grass) => (
			<article class="card overflow-hidden pricing-card" style={`background-color: ${grass.color}`}>
				<div class="p-6 lg:p-8 space-y-5">
					<div class="flex items-center justify-between">
						<span
							class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white rounded-full"
							style={`background-color: ${grass.accent}`}
						>
							{grass.name}
						</span>
						<span class="text-xs text-text-secondary font-medium">por m²</span>
					</div>

					<div class="space-y-3">
						<div class="flex items-end justify-between gap-3 pb-3 border-b border-white/40">
							<div>
								<p class="text-xs uppercase tracking-wider text-text-secondary font-semibold">Sin instalación</p>
								<p class="text-3xl font-heading font-semibold mt-1" style={`color: ${grass.accent}`}>
									${grass.priceSin}
								</p>
							</div>
							<svg class="w-5 h-5 text-text-secondary/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
								<path d="M3 3h18v18H3z"/>
								<path d="M3 9h18M9 21V9"/>
							</svg>
						</div>
						<div class="flex items-end justify-between gap-3">
							<div>
								<p class="text-xs uppercase tracking-wider text-text-secondary font-semibold">Con instalación</p>
								<p class="text-3xl font-heading font-semibold mt-1" style={`color: ${grass.accent}`}>
									${grass.priceCon}
								</p>
							</div>
							<svg class="w-5 h-5" style={`color: ${grass.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
								<path d="M20 7L9 18l-5-5"/>
							</svg>
						</div>
					</div>

					<p class="text-sm text-text-secondary italic pt-2">{grass.headline}</p>
				</div>
			</article>
		))}
	</div>

	<InstallationInfo />
</div>
