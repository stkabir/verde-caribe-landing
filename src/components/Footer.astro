---
const footerLinks = [
	{
		title: 'Explorar',
		links: [
			{ href: '/#inicio', label: 'Inicio' },
			{ href: '/#pastos', label: 'Pastos' },
			{ href: '/#nosotros', label: 'Nosotros' },
			{ href: '/#contacto', label: 'Contacto' },
		]
	},
	{
		title: 'Servicios',
		links: [
			{ href: '/#pedidos', label: 'Cotizar' },
			{ href: '/#pastos', label: 'Nuestras variedades' },
			{ href: '/#contacto', label: 'Asesoría técnica' },
		]
	},
];

const locations = ['Cancún', 'Playa del Carmen', 'Puerto Morelos', 'Tulum'];
---

<footer class="bg-foreground text-bg py-12 lg:py-16 px-6 lg:px-8 rounded-t-[60px]">
	<div class="max-w-7xl mx-auto">
		<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16 pb-12 border-b border-bg/10">
			<!-- Brand -->
			<div class="lg:col-span-2 space-y-6">
				<a href="/#inicio" class="font-heading text-3xl text-bg hover:text-sage transition-colors duration-300">
					Verde Caribe
				</a>
				<p class="text-bg/70 max-w-md leading-relaxed">
					Cultivamos y seleccionamos pastos resistentes al clima tropical del Caribe mexicano.
					Calidad, experiencia y servicio puntual para tu proyecto.
				</p>
				<div class="flex flex-wrap gap-3">
					{locations.map(location => (
						<span class="px-3 py-1 text-xs font-medium bg-bg/10 rounded-full">
							{location}
						</span>
					))}
				</div>
			</div>

			<!-- Navigation -->
			{footerLinks.map(group => (
				<div class="space-y-4">
					<h4 class="text-xs uppercase tracking-widest text-bg/50 font-semibold">{group.title}</h4>
					<ul class="space-y-3">
						{group.links.map(link => (
							<li>
								<a
									href={link.href}
									class="text-bg/70 hover:text-bg transition-colors duration-300 text-sm"
								>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
			<p class="text-sm text-bg/50">
				&copy; {new Date().getFullYear()} Verde Caribe. Todos los derechos reservados.
			</p>
			<p class="text-sm text-bg/50">
				Pastos vivos para el Caribe mexicano
			</p>
		</div>
	</div>
</footer>