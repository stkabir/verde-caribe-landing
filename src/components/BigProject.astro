---
const WA_NUMBER = '529982592189';
---

<div class="bg-surface rounded-3xl shadow-large p-6 lg:p-10 big-project" data-big-project>
	<div class="grid lg:grid-cols-2 gap-8 items-start">
		<div class="space-y-4">
			<p class="section-eyebrow">A medida</p>
			<h3 class="text-2xl font-heading">Conversemos tu proyecto grande</h3>
			<p class="text-text-secondary leading-relaxed">
				Para desarrollos, hoteles, residenciales o cualquier proyecto que requiera atención especial.
				Cuéntanos los puntos clave y nos pondremos en contacto por WhatsApp para agendar una visita.
			</p>
			<ul class="space-y-2 text-sm text-text-secondary">
				<li class="flex items-center gap-2">
					<svg class="w-4 h-4 text-sage flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
					Asesoría técnica dedicada
				</li>
				<li class="flex items-center gap-2">
					<svg class="w-4 h-4 text-sage flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
					Visita técnica sin compromiso
				</li>
				<li class="flex items-center gap-2">
					<svg class="w-4 h-4 text-sage flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
					Cotización personalizada a tu proyecto
				</li>
			</ul>
		</div>

		<form class="space-y-4" data-form>
			<div class="grid sm:grid-cols-2 gap-4">
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Nombre</span>
					<input type="text" name="name" required placeholder="Tu nombre" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Teléfono</span>
					<input type="tel" name="phone" required placeholder="998 123 4567" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
			</div>

			<label class="space-y-1.5 block">
				<span class="text-sm font-semibold text-foreground">Ubicación del proyecto</span>
				<input type="text" name="location" required placeholder="Ciudad, colonia o desarrollo" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
			</label>

			<div class="grid sm:grid-cols-2 gap-4">
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Área aproximada (m²)</span>
					<input type="number" name="m2" min="0" placeholder="500" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
				<label class="space-y-1.5">
					<span class="text-sm font-semibold text-foreground">Fecha estimada</span>
					<input type="text" name="date" placeholder="Ej. marzo 2026" class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"/>
				</label>
			</div>

			<label class="space-y-1.5 block">
				<span class="text-sm font-semibold text-foreground">Cuéntanos del proyecto</span>
				<textarea name="description" rows="3" placeholder="Desarrollo residencial con 20 casas, área común con alberca..." class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none form-input"></textarea>
			</label>

			<button type="button" data-send class="btn btn-primary w-full sm:w-auto">
				<svg class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 4.9L2 22l5.3-1.4c1.4.8 3 1.2 4.7 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
				Conversemos por WhatsApp
			</button>
		</form>
	</div>
</div>

<script define:vars={{ WA_NUMBER }}>
	const root = document.querySelector('[data-big-project]');
	if (root) {
		const form = root.querySelector('[data-form]');
		const sendBtn = root.querySelector('[data-send]');

		sendBtn?.addEventListener('click', () => {
			const fd = new FormData(form);
			const name = (fd.get('name') || '').toString().trim();
			const phone = (fd.get('phone') || '').toString().trim();
			const location = (fd.get('location') || '').toString().trim();
			const m2 = (fd.get('m2') || '').toString().trim();
			const date = (fd.get('date') || '').toString().trim();
			const description = (fd.get('description') || '').toString().trim();

			if (!name || !phone || !location) {
				alert('Por favor completa nombre, teléfono y ubicación.');
				return;
			}

			const lines = [
				'🏗️ *Proyecto grande — Verde Caribe*',
				'',
				`👤 *Nombre:* ${name}`,
				`📞 *Teléfono:* ${phone}`,
				`📍 *Ubicación:* ${location}`,
			];
			if (m2) lines.push(`📐 *Área aproximada:* ${m2} m²`);
			if (date) lines.push(`📅 *Fecha estimada:* ${date}`);
			if (description) {
				lines.push('', '📝 *Descripción:*', description);
			}
			lines.push('', '_Quisiera agendar una visita técnica._');

			const msg = encodeURIComponent(lines.join('\n'));
			window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank');
		});
	}
</script>
