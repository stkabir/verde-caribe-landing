---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Verde Caribe - Pastos vivos de alta calidad' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Pastos vivos de alta calidad para el Caribe mexicano. Cultivamos y seleccionamos pastos resistentes al clima tropical. Servicio en Cancún, Playa del Carmen, Puerto Morelos y Tulum." />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Source+Sans+3:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="antialiased min-h-screen flex flex-col">
		<slot />
	</body>
</html>