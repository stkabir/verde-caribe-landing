---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Pastos vivos en Cancún y Riviera Maya | Verde Caribe',
	description = 'Venta e instalación de pasto San Agustín, Pasto Chino y Zoysia en Cancún, Playa del Carmen, Puerto Morelos y Tulum. Incluye tierra fertilizada, mano de obra y transporte. Cotiza por WhatsApp.',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://verdecaribe.com';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/images/og-cover.jpg`;
const logoUrl = `${siteUrl}/images/logo.png`;

const localBusiness = {
	'@context': 'https://schema.org',
	'@type': 'GardenStore',
	'@id': `${siteUrl}/#business`,
	name: 'Verde Caribe',
	image: logoUrl,
	url: siteUrl,
	telephone: '+52-998-259-2189',
	email: 'hola@verdecaraibe.mx',
	priceRange: '$$',
	description: 'Cultivamos y seleccionamos pastos resistentes al clima tropical del Caribe mexicano. Servicio en Cancún, Playa del Carmen, Puerto Morelos y Tulum.',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Cancún',
		addressRegion: 'Quintana Roo',
		addressCountry: 'MX',
	},
	geo: {
		'@type': 'GeoCoordinates',
		latitude: 21.1619,
		longitude: -86.8515,
	},
	areaServed: [
		{ '@type': 'City', name: 'Cancún' },
		{ '@type': 'City', name: 'Playa del Carmen' },
		{ '@type': 'City', name: 'Puerto Morelos' },
		{ '@type': 'City', name: 'Tulum' },
	],
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '08:00',
			closes: '18:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '09:00',
			closes: '14:00',
		},
	],
	sameAs: [
		'https://facebook.com/verdecaraibe',
		'https://instagram.com/verdecaraibe',
	],
};

const installationService = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	'@id': `${siteUrl}/#service-installation`,
	serviceType: 'Instalación de pasto',
	name: 'Venta e instalación profesional de pasto',
	provider: { '@id': `${siteUrl}/#business` },
	areaServed: [
		{ '@type': 'City', name: 'Cancún' },
		{ '@type': 'City', name: 'Playa del Carmen' },
		{ '@type': 'City', name: 'Puerto Morelos' },
		{ '@type': 'City', name: 'Tulum' },
	],
	description: 'Instalación profesional de pasto en Cancún y Riviera Maya. Incluye tierra fertilizada, mano de obra y transporte dentro de Cancún. Servicio de transporte disponible fuera de Cancún desde $350.',
	offers: {
		'@type': 'AggregateOffer',
		priceCurrency: 'MXN',
		lowPrice: '130',
		highPrice: '267',
		offerCount: '3',
	},
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="pasto Cancún, pasto Riviera Maya, venta de pasto, instalación de pasto, San Agustín, pasto chino, zoysia, jardín Cancún, diseño de jardines, paisajismo Quintana Roo, mantenimiento de jardín" />
		<meta name="author" content="Verde Caribe" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
		<meta name="theme-color" content="#8C9A84" />
		<meta name="color-scheme" content="light" />
		<meta name="format-detection" content="telephone=yes" />

		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/images/apple-touch-icon.png" sizes="180x180" />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Verde Caribe" />
		<meta property="og:locale" content="es_MX" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Verde Caribe - Pastos vivos en Cancún y Riviera Maya" />
		<meta property="og:image:type" content="image/jpeg" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonical} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content="Verde Caribe - Pastos vivos en Cancún y Riviera Maya" />

		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="Verde Caribe" />

		<meta name="geo.region" content="MX-ROO" />
		<meta name="geo.placename" content="Cancún" />
		<meta name="geo.position" content="21.1619;-86.8515" />
		<meta name="ICBM" content="21.1619, -86.8515" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://images.unsplash.com" />

		<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
		<script type="application/ld+json" set:html={JSON.stringify(installationService)} />
	</head>
	<body class="antialiased min-h-screen flex flex-col">
		<slot />
	</body>
</html>
