---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { grasses } from '../data/pastos';
import type { Grass } from '../data/pastos';
---

<Layout title="Verde Caribe - Pastos vivos de alta calidad">
	<Navbar />
	<div class="paper-grain" aria-hidden="true"></div>

	<main class="flex-1">
		<!-- Hero Section -->
		<section id="inicio" class="relative min-h-screen flex items-center py-24 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
				<div class="space-y-8 animate-fade-up">
					<p class="section-eyebrow">Pastos vivos de alta calidad</p>
					<h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-semibold leading-tight">
						Verde Caribe<br />
						<span class="text-2xl md:text-3xl lg:text-4xl font-body font-normal text-text-secondary italic">
							Tapetes de pasto listos para transformar tus espacios
						</span>
					</h1>
					<p class="text-lg text-text-secondary max-w-xl leading-relaxed">
						Cultivamos y seleccionamos pastos resistentes al clima tropical del Caribe mexicano.
						Nuestro equipo te asesora para elegir la variedad ideal y llevarla a tu jardín,
						proyecto comercial o área recreativa.
					</p>
					<div class="flex flex-wrap gap-4">
						<a href="#pastos" class="btn btn-primary">
							Conocer variedades
						</a>
						<a href="#pedidos" class="btn btn-secondary">
							Solicitar cotización
						</a>
					</div>
				</div>
				<div class="relative animate-fade-up" style="animation-delay: 0.2s;">
					<div class="absolute inset-0 bg-gradient-to-br from-sage/30 via-sage/20 to-clay/30 rounded-[120px] blur-3xl"></div>
					<div class="relative rounded-[120px] overflow-hidden shadow-large aspect-[4/5] max-h-[550px] hero-image">
						<img
							src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
							alt="Pasto verde exuberante"
							class="w-full h-full object-cover"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Pastos Section -->
		<section id="pastos" class="py-24 lg:py-32 px-6 lg:px-8 bg-gradient-to-b from-transparent via-clay/10 to-transparent">
			<div class="max-w-7xl mx-auto">
				<header class="text-center max-w-2xl mx-auto mb-16 space-y-4">
					<p class="section-eyebrow">Nuestras variedades</p>
					<h2 class="text-4xl md:text-5xl lg:text-6xl font-heading">
						Pastos diseñados para tu <em class="text-sage italic">proyecto</em>
					</h2>
					<p class="text-lg text-text-secondary">
						Todas nuestras variedades se producen en campo propio y se entregan frescas
						para garantizar una instalación uniforme.
					</p>
				</header>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
					{grasses.map((grass: Grass, index: number) => (
						<article
							class={`card group ${index % 2 === 1 ? 'lg:translate-y-12' : ''}`}
						>
							<div class="relative overflow-hidden">
								<img
									src={grass.image}
									alt={`Pasto ${grass.name}`}
									loading="lazy"
									class="w-full aspect-[4/3] object-cover transition-transform duration-700 group-hover:scale-105"
								/>
								<div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-foreground/10 to-transparent"></div>
							</div>
							<div class="p-6 lg:p-8 space-y-4 grass-info" style={`background-color: ${grass.color}`}>
								<span
									class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white rounded-full"
									style={`background-color: ${grass.accent}`}
								>
									{grass.name}
								</span>
								<h3 class="text-2xl font-heading">{grass.name}</h3>
								<p class="text-text-secondary italic">{grass.headline}</p>
								<p class="text-text-secondary text-sm line-clamp-3">{grass.longDescription}</p>

								<div class="space-y-2 pt-2">
									<p class="text-xs uppercase tracking-wider text-text-secondary font-semibold">Beneficios</p>
									<ul class="space-y-2">
										{grass.benefits.map((benefit: string) => (
											<li class="flex items-center gap-2 text-sm">
												<svg class="w-4 h-4 flex-shrink-0" style={`color: ${grass.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
													<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
													<path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
												</svg>
												{benefit}
											</li>
										))}
									</ul>
								</div>

								<div class="flex items-center gap-2 text-sm p-3 rounded-xl bg-white/60">
									<svg class="w-4 h-4 flex-shrink-0" style={`color: ${grass.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<circle cx="12" cy="12" r="5"/>
										<line x1="12" y1="1" x2="12" y2="3"/>
										<line x1="12" y1="21" x2="12" y2="23"/>
										<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
										<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
										<line x1="1" y1="12" x2="3" y2="12"/>
										<line x1="21" y1="12" x2="23" y2="12"/>
									</svg>
									<span class="text-text-secondary">Ideal para: <strong class="text-foreground">{grass.recommendedFor}</strong></span>
								</div>

								{/* TODO: Future - Add detail page with more photos for each grass type */}
								{/*
								<a
									href={`/pasto/${grass.slug}`}
									class="inline-flex items-center gap-2 font-semibold text-sm transition-all duration-300 hover:gap-3"
									style={`color: ${grass.accent}`}
								>
									Ver ficha técnica
									<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<line x1="5" y1="12" x2="19" y2="12"/>
										<polyline points="12 5 19 12 12 19"/>
									</svg>
								</a>
								*/}
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Nosotros Section -->
		<section id="nosotros" class="py-24 lg:py-32 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="relative">
						<div class="absolute -inset-4 bg-gradient-to-br from-sage/20 via-clay/20 to-terracotta/10 rounded-[80px] blur-2xl"></div>
						<div class="relative grid grid-cols-2 gap-4">
							<div class="space-y-4">
								<div class="rounded-3xl overflow-hidden shadow-medium aspect-[4/5] gallery-image">
									<img
										src="https://images.unsplash.com/photo-1558904541-efa843a96f01?auto=format&fit=crop&w=600&q=80"
										alt="Cultivo de pasto"
										class="w-full h-full object-cover"
									/>
								</div>
							</div>
							<div class="space-y-4 pt-8">
								<div class="rounded-3xl overflow-hidden shadow-medium aspect-[4/5] gallery-image">
									<img
										src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?auto=format&fit=crop&w=600&q=80"
										alt="Pasto verde exuberante"
										class="w-full h-full object-cover"
									/>
								</div>
							</div>
						</div>
					</div>

					<div class="space-y-8">
						<p class="section-eyebrow">Sobre nosotros</p>
						<h2 class="text-4xl md:text-5xl font-heading">
							Más de <em class="text-sage italic">20 años</em> cultivando verde en el Caribe
						</h2>
						<p class="text-lg text-text-secondary leading-relaxed">
							Verde Caribe nació de la pasión por el campo y el compromiso con la calidad.
							Desde nuestros campos en Quintana Roo, producimos tapetes de pasto de la más alta
							calidad para proyectos residenciales, comerciales y recreativos en toda la Riviera Maya.
						</p>

						<div class="grid grid-cols-2 gap-6">
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card">
								<p class="text-4xl font-heading font-bold text-sage">20+</p>
								<p class="text-sm text-text-secondary">Años de experiencia</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card">
								<p class="text-4xl font-heading font-bold text-sage">100%</p>
								<p class="text-sm text-text-secondary">Producción propia</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card">
								<p class="text-4xl font-heading font-bold text-sage">500+</p>
								<p class="text-sm text-text-secondary">Proyectos completados</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card">
								<p class="text-4xl font-heading font-bold text-sage">4</p>
								<p class="text-sm text-text-secondary">Ciudades de cobertura</p>
							</div>
						</div>

						<div class="space-y-3">
							<div class="flex items-center gap-3">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Pasto cosechado y entregado el mismo día</span>
							</div>
							<div class="flex items-center gap-3">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Asesoría técnica gratuita</span>
							</div>
							<div class="flex items-center gap-3">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Garantía de calidad en cada metro²</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Quote/CTA Section -->
		<section id="pedidos" class="py-24 lg:py-32 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="bg-surface rounded-3xl shadow-large p-8 lg:p-16">
					<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
						<div class="space-y-6">
							<p class="section-eyebrow">Asesoría especializada</p>
							<h2 class="text-4xl md:text-5xl font-heading">
								¿Planeas instalar pasto verde de <em class="text-sage">inmediato</em>?
							</h2>
							<p class="text-lg text-text-secondary leading-relaxed">
								Nuestro equipo técnico evalúa tu terreno, recomienda la variedad adecuada
								y coordina la entrega puntual. Completa el formulario para recibir una
								propuesta detallada en menos de 24 horas.
							</p>
							<div class="flex items-center gap-4 pt-4">
								<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
									<circle cx="12" cy="10" r="3"/>
								</svg>
								<span class="text-text-secondary text-sm">Cancún · Playa del Carmen · Puerto Morelos · Tulum</span>
							</div>
						</div>

						<form class="space-y-6" id="quote-form">
							<div class="grid sm:grid-cols-2 gap-4">
								<label class="space-y-2">
									<span class="text-sm font-semibold text-foreground">Nombre completo</span>
									<input
										type="text"
										name="name"
										placeholder="María González"
										required
										class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
									/>
								</label>
								<label class="space-y-2">
									<span class="text-sm font-semibold text-foreground">Correo electrónico</span>
									<input
										type="email"
										name="email"
										placeholder="hola@ejemplo.com"
										required
										class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
									/>
								</label>
							</div>

							<div class="grid sm:grid-cols-2 gap-4">
								<label class="space-y-2">
									<span class="text-sm font-semibold text-foreground">Teléfono</span>
									<input
										type="tel"
										name="phone"
										placeholder="55 1234 5678"
										class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
									/>
								</label>
								<label class="space-y-2">
									<span class="text-sm font-semibold text-foreground">Variedad de interés</span>
									<select
										name="grass"
										required
										class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
									>
										<option value="">Selecciona un pasto</option>
										{grasses.map((grass: Grass) => (
											<option value={grass.slug}>{grass.name}</option>
										))}
									</select>
								</label>
							</div>

							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Área estimada (m²)</span>
								<div class="flex flex-wrap gap-4">
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="area" value="50" class="w-4 h-4 accent-[#8C9A84]" />
										<span class="text-sm text-text-secondary">Hasta 50 m²</span>
									</label>
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="area" value="150" class="w-4 h-4 accent-[#8C9A84]" />
										<span class="text-sm text-text-secondary">50 - 150 m²</span>
									</label>
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="area" value="mas" class="w-4 h-4 accent-[#8C9A84]" />
										<span class="text-sm text-text-secondary">Más de 150 m²</span>
									</label>
								</div>
							</label>

							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Cuéntanos tu proyecto</span>
								<textarea
									name="message"
									rows="4"
									placeholder="Buscamos renovar el jardín frontal y el área de juegos..."
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none"
								></textarea>
							</label>

							<button type="submit" class="btn btn-primary w-full sm:w-auto">
								Solicitar cotización
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<!-- Contacto Section -->
		<section id="contacto" class="py-24 lg:py-32 px-6 lg:px-8 bg-clay/20">
			<div class="max-w-7xl mx-auto">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="space-y-8">
						<p class="section-eyebrow">Contáctanos</p>
						<h2 class="text-4xl md:text-5xl font-heading">
							¿Tienes preguntas? <em class="text-sage italic">Hablanos</em>
						</h2>
						<p class="text-lg text-text-secondary">
							Nuestro equipo está listo para responder tus preguntas sobre variedades,
							precios, instalación y mantenimiento de pasto.
						</p>

						<div class="space-y-4">
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">Teléfono</p>
									<p class="font-semibold">+52 998 123 4567</p>
								</div>
							</div>
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
										<polyline points="22,6 12,13 2,6"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">Correo</p>
									<p class="font-semibold">hola@verdecaraibe.mx</p>
								</div>
							</div>
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
										<circle cx="12" cy="10" r="3"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">Ubicación</p>
									<p class="font-semibold">Cancún, Quintana Roo, México</p>
								</div>
							</div>
						</div>
					</div>

					<div class="bg-surface rounded-3xl shadow-large p-8 lg:p-12">
						<form class="space-y-6" id="contact-form">
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Nombre completo</span>
								<input
									type="text"
									name="name"
									placeholder="Tu nombre"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
								/>
							</label>
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Correo electrónico</span>
								<input
									type="email"
									name="email"
									placeholder="tu@correo.com"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2"
								/>
							</label>
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Mensaje</span>
								<textarea
									name="message"
									rows="4"
									placeholder="¿En qué podemos ayudarte?"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none"
								></textarea>
							</label>
							<button type="submit" class="btn btn-primary w-full">
								Enviar mensaje
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const cards = document.querySelectorAll('.card');

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							(entry.target as HTMLElement).style.opacity = '1';
							(entry.target as HTMLElement).style.transform = 'translateY(0)';
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1 }
			);

			cards.forEach((card, index) => {
				const el = card as HTMLElement;
				el.style.opacity = '0';
				el.style.transform = 'translateY(2rem)';
				el.style.transition = `opacity 0.6s ease-out ${index * 0.1}s, transform 0.6s ease-out ${index * 0.1}s`;
				observer.observe(card);
			});

			document.querySelectorAll('a[href^="#"]').forEach(anchor => {
				anchor.addEventListener('click', function(e) {
					e.preventDefault();
					const target = document.querySelector(this.getAttribute('href') as string);
					if (target) {
						target.scrollIntoView({ behavior: 'smooth' });
					}
				});
			});
		});
	</script>
</Layout>