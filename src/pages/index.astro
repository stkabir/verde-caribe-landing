---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PricingTable from '../components/PricingTable.astro';
import QuoteGate from '../components/QuoteGate.astro';
import QuickQuote from '../components/QuickQuote.astro';
import GardenWizard from '../components/GardenWizard.astro';
import BigProject from '../components/BigProject.astro';
import { grasses } from '../data/pastos';
import type { Grass } from '../data/pastos';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://verdecaribe.com';

const productSchemas = grasses.map((g) => ({
	'@context': 'https://schema.org',
	'@type': 'Product',
	'@id': `${siteUrl}/#product-${g.slug}`,
	name: g.name,
	image: g.image,
	description: g.longDescription,
	category: 'Pasto para jardín',
	brand: {
		'@type': 'Brand',
		name: 'Verde Caribe',
	},
	offers: {
		'@type': 'AggregateOffer',
		priceCurrency: 'MXN',
		lowPrice: g.priceSin,
		highPrice: g.priceCon,
		offerCount: 2,
		availability: 'https://schema.org/InStock',
		priceValidUntil: '2026-12-31',
	},
	seller: { '@id': `${siteUrl}/#business` },
}));
---

<Layout title="Pastos vivos en Cancún y Riviera Maya | Verde Caribe - Cotiza por WhatsApp">
	<Navbar />
	<div class="paper-grain" aria-hidden="true"></div>

	<main class="flex-1">
		<!-- Hero Section -->
		<section id="inicio" class="relative min-h-screen flex items-center py-24 px-6 lg:px-8 overflow-hidden">
			<div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
				<div class="space-y-8">
					<p class="section-eyebrow hero-eyebrow">Pastos vivos de alta calidad</p>
					<h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-semibold leading-tight overflow-hidden">
						<span class="hero-title block" data-split="chars">Verde Caribe</span>
						<span class="block text-2xl md:text-3xl lg:text-4xl font-body font-normal text-text-secondary italic mt-4">
							<span class="hero-subtitle" data-split="words">Tapetes de pasto listos para transformar tus espacios</span>
						</span>
					</h1>
					<p class="text-lg text-text-secondary max-w-xl leading-relaxed hero-description">
						Cultivamos y seleccionamos pastos resistentes al clima tropical del Caribe mexicano.
						Nuestro equipo te asesora para elegir la variedad ideal y llevarla a tu jardín,
						proyecto comercial o área recreativa.
					</p>
					<div class="flex flex-wrap gap-4 hero-buttons">
						<a href="#pastos" class="btn btn-primary">Conocer variedades</a>
						<a href="#cotizar" class="btn btn-secondary">Cotizar ahora</a>
					</div>
				</div>
				<div class="relative hero-image-container" data-parallax="hero">
					<div class="absolute inset-0 bg-gradient-to-br from-sage/30 via-sage/20 to-clay/30 rounded-[120px] blur-3xl hero-glow"></div>
					<div class="relative rounded-[120px] overflow-hidden shadow-large aspect-[4/5] max-h-[550px] hero-image">
						<img
							src="https://scontent.fcjs3-2.fna.fbcdn.net/v/t39.30808-6/607836880_122151798422643244_5803238958415024448_n.jpg?stp=dst-jpg_tt6&cstp=mx1536x2048&ctp=s1536x2048&_nc_cat=103&ccb=1-7&_nc_sid=833d8c&_nc_ohc=-l6bJEvOEBYQ7kNvwGG5VtX&_nc_oc=AdqYC-u66fbzyAR3pNJmS-azGtpmS6fJy2p77qUWrhiIixJ-4AvSO20EG8LawHM97-3Mq731wf3SOlp7_7x_fGyF&_nc_zt=23&_nc_ht=scontent.fcjs3-2.fna&_nc_gid=BL57-cDCDk7IdrK6vmxwQQ&_nc_ss=7b2a8&oh=00_Af-TH94nGSuISREGejAg1-0JH1fRhmIGj_pJZtdAut2yvQ&oe=6A2A7FA7"
							alt="Jardín con pasto verde exuberante recién instalado por Verde Caribe en Cancún"
							loading="eager"
							fetchpriority="high"
							width="1200"
							height="1500"
							class="w-full h-full object-cover"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Pastos Section -->
		<section id="pastos" class="py-24 lg:py-32 px-6 lg:px-8 bg-gradient-to-b from-transparent via-clay/10 to-transparent">
			<div class="max-w-7xl mx-auto">
				<header class="text-center max-w-2xl mx-auto mb-16 space-y-4 section-header">
					<p class="section-eyebrow">Nuestras variedades</p>
					<h2 class="text-4xl md:text-5xl lg:text-6xl font-heading section-title">
						Pastos diseñados para tu <em class="text-sage italic">proyecto</em>
					</h2>
					<p class="text-lg text-text-secondary section-desc">
						Todas nuestras variedades se producen en campo propio y se entregan frescas
						para garantizar una instalación uniforme.
					</p>
				</header>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
					{grasses.map((grass: Grass, index: number) => (
						<article
							class={`card group grass-card ${index % 2 === 1 ? 'lg:translate-y-12' : ''}`}
							data-scroll="card"
						>
							<div class="relative overflow-hidden">
								<img
									src={grass.image}
									alt={grass.slug === 'san-agustin' ? 'Tapete de pasto San Agustín recién instalado en jardín residencial de Cancún' : grass.slug === 'pasto-chino' ? 'Pasto chino ornamental en camellón decorativo en Playa del Carmen' : 'Césped Zoysia verde esmeralda en jardín expuesto al sol en la Riviera Maya'}
									loading="lazy"
									width="1200"
									height="900"
									class="w-full aspect-[4/3] object-cover transition-transform duration-700 group-hover:scale-105"
								/>
								<div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-foreground/10 to-transparent"></div>
							</div>
							<div class="p-6 lg:p-8 space-y-4 grass-info" style={`background-color: ${grass.color}`}>
								<span
									class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white rounded-full"
									style={`background-color: ${grass.accent}`}
								>
									{grass.name}
								</span>
								<h3 class="text-2xl font-heading">{grass.name}</h3>
								<p class="text-text-secondary italic">{grass.headline}</p>
								<p class="text-text-secondary text-sm line-clamp-3">{grass.longDescription}</p>

								<div class="space-y-2 pt-2">
									<p class="text-xs uppercase tracking-wider text-text-secondary font-semibold">Beneficios</p>
									<ul class="space-y-2">
										{grass.benefits.map((benefit: string) => (
											<li class="flex items-center gap-2 text-sm">
												<svg class="w-4 h-4 flex-shrink-0" style={`color: ${grass.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
													<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
													<path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
												</svg>
												{benefit}
											</li>
										))}
									</ul>
								</div>

								<div class="flex items-center gap-2 text-sm p-3 rounded-xl bg-white/60">
									<svg class="w-4 h-4 flex-shrink-0" style={`color: ${grass.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<circle cx="12" cy="12" r="5"/>
										<line x1="12" y1="1" x2="12" y2="3"/>
										<line x1="12" y1="21" x2="12" y2="23"/>
										<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
										<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
										<line x1="1" y1="12" x2="3" y2="12"/>
										<line x1="21" y1="12" x2="23" y2="12"/>
									</svg>
									<span class="text-text-secondary">Ideal para: <strong class="text-foreground">{grass.recommendedFor}</strong></span>
								</div>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Nosotros Section -->
		<section id="nosotros" class="py-24 lg:py-32 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="relative gallery-section" data-reveal="fade">
						<div class="absolute -inset-4 bg-gradient-to-br from-sage/20 via-clay/20 to-terracotta/10 rounded-[80px] blur-2xl"></div>
						<div class="relative grid grid-cols-2 gap-4">
							<div class="space-y-4">
								<div class="rounded-3xl overflow-hidden shadow-medium aspect-[4/5] gallery-image" data-scroll="image">
									<img
										src="https://images.unsplash.com/photo-1558904541-efa843a96f01?auto=format&fit=crop&w=600&q=80"
										alt="Cultivo de pasto en campos de producción propios de Verde Caribe en Quintana Roo"
										loading="lazy"
										width="600"
										height="750"
										class="w-full h-full object-cover"
									/>
								</div>
							</div>
							<div class="space-y-4 pt-8">
								<div class="rounded-3xl overflow-hidden shadow-medium aspect-[4/5] gallery-image" data-scroll="image">
									<img
										src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?auto=format&fit=crop&w=600&q=80"
										alt="Pasto verde recién instalado en jardín residencial en Cancún"
										loading="lazy"
										width="600"
										height="750"
										class="w-full h-full object-cover"
									/>
								</div>
							</div>
						</div>
					</div>

					<div class="space-y-8 about-content" data-reveal="fade">
						<p class="section-eyebrow">Sobre nosotros</p>
						<h2 class="text-4xl md:text-5xl font-heading">
							Más de <em class="text-sage italic">20 años</em> cultivando verde en el Caribe
						</h2>
						<p class="text-lg text-text-secondary leading-relaxed">
							Verde Caribe nació de la pasión por el campo y el compromiso con la calidad.
							Desde nuestros campos en Quintana Roo, producimos tapetes de pasto de la más alta
							calidad para proyectos residenciales, comerciales y recreativos en toda la Riviera Maya.
						</p>

						<div class="grid grid-cols-2 gap-6">
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card" data-scroll="stat">
								<p class="text-4xl font-heading font-bold text-sage stat-number" data-count="20">20+</p>
								<p class="text-sm text-text-secondary">Años de experiencia</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card" data-scroll="stat">
								<p class="text-4xl font-heading font-bold text-sage stat-number" data-count="100">100%</p>
								<p class="text-sm text-text-secondary">Producción propia</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card" data-scroll="stat">
								<p class="text-4xl font-heading font-bold text-sage stat-number" data-count="500">500+</p>
								<p class="text-sm text-text-secondary">Proyectos completados</p>
							</div>
							<div class="p-6 bg-surface rounded-2xl shadow-soft stat-card" data-scroll="stat">
								<p class="text-4xl font-heading font-bold text-sage">4</p>
								<p class="text-sm text-text-secondary">Ciudades de cobertura</p>
							</div>
						</div>

						<div class="space-y-3 feature-list">
							<div class="flex items-center gap-3 feature-item">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Pasto cosechado y entregado el mismo día</span>
							</div>
							<div class="flex items-center gap-3 feature-item">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Asesoría técnica gratuita</span>
							</div>
							<div class="flex items-center gap-3 feature-item">
								<div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-4 h-4 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<polyline points="20 6 9 17 4 12"/>
									</svg>
								</div>
								<span class="text-foreground">Garantía de calidad en cada metro²</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Cotizar Section -->
		<section id="cotizar" class="py-24 lg:py-32 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto space-y-20 lg:space-y-24 cta-section" data-reveal="fade">
				<PricingTable />

				<QuoteGate />

				<div class="space-y-12 lg:space-y-16">
					<div id="form-quick" class="scroll-mt-24">
						<QuickQuote />
					</div>
					<div id="form-wizard" class="scroll-mt-24">
						<GardenWizard />
					</div>
					<div id="form-project" class="scroll-mt-24">
						<BigProject />
					</div>
				</div>
			</div>
		</section>

		<!-- Contacto Section -->
		<section id="contacto" class="py-24 lg:py-32 px-6 lg:px-8 bg-clay/20">
			<div class="max-w-7xl mx-auto">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="space-y-8 contact-info" data-reveal="fade">
						<p class="section-eyebrow">Contáctanos</p>
						<h2 class="text-4xl md:text-5xl font-heading">
							¿Tienes preguntas? <em class="text-sage italic">Hablanos</em>
						</h2>
						<p class="text-lg text-text-secondary">
							Nuestro equipo está listo para responder tus preguntas sobre variedades,
							precios, instalación y mantenimiento de pasto.
						</p>

						<div class="space-y-4">
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">WhatsApp / Teléfono</p>
									<p class="font-semibold">+52 998 259 2189</p>
								</div>
							</div>
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
										<polyline points="22,6 12,13 2,6"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">Correo</p>
									<p class="font-semibold">hola@verdecaraibe.mx</p>
								</div>
							</div>
							<div class="flex items-center gap-4 contact-item cursor-pointer">
								<div class="w-12 h-12 rounded-full bg-sage/20 flex items-center justify-center">
									<svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
										<circle cx="12" cy="10" r="3"/>
									</svg>
								</div>
								<div>
									<p class="text-sm text-text-secondary">Ubicación</p>
									<p class="font-semibold">Cancún, Quintana Roo, México</p>
								</div>
							</div>
						</div>
					</div>

					<div class="bg-surface rounded-3xl shadow-large p-8 lg:p-12 contact-form-container" data-reveal="fade">
						<form class="space-y-6" id="contact-form">
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Nombre completo</span>
								<input
									type="text"
									name="name"
									placeholder="Tu nombre"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"
								/>
							</label>
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Correo electrónico</span>
								<input
									type="email"
									name="email"
									placeholder="tu@correo.com"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 form-input"
								/>
							</label>
							<label class="space-y-2">
								<span class="text-sm font-semibold text-foreground">Mensaje</span>
								<textarea
									name="message"
									rows="4"
									placeholder="¿En qué podemos ayudarte?"
									required
									class="w-full px-4 py-3 rounded-xl border border-border bg-surface-muted text-foreground placeholder:text-text-secondary/50 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-sage focus:ring-offset-2 resize-none form-input"
								></textarea>
							</label>
							<button type="submit" class="btn btn-primary w-full">
								Enviar mensaje
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';

		gsap.registerPlugin(ScrollTrigger);

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!prefersReducedMotion) {
			document.addEventListener('DOMContentLoaded', () => {
				initHeroAnimations();
				initScrollAnimations();
				initParallax();
			});
		}

		function initHeroAnimations() {
			const title = document.querySelector('.hero-title');
			const subtitle = document.querySelector('.hero-subtitle');

			if (title) {
				const chars = splitChars(title as HTMLElement);
				setTimeout(() => {
					animateChars(chars, { y: 80, stagger: 0.04, duration: 0.9, rotation: 2 });
				}, 300);
			}

			if (subtitle) {
				const words = splitWords(subtitle as HTMLElement);
				setTimeout(() => {
					animateWords(words, { y: 35, stagger: 0.1, duration: 0.65, ease: 'power2.out' });
				}, 900);
			}

			gsap.from('.hero-eyebrow', {
				opacity: 0,
				y: 20,
				duration: 0.8,
				delay: 0.2,
				ease: 'power3.out'
			});

			gsap.from('.hero-description', {
				opacity: 0,
				y: 30,
				duration: 0.8,
				delay: 1.2,
				ease: 'power3.out'
			});

			gsap.from('.hero-buttons a', {
				opacity: 0,
				y: 20,
				duration: 0.6,
				delay: 1.4,
				stagger: 0.1,
				ease: 'power3.out'
			});
		}

		function initScrollAnimations() {
			gsap.from('.grass-card', {
				scrollTrigger: {
					trigger: '.grass-card',
					start: 'top 85%',
					once: true
				},
				y: 80,
				opacity: 0,
				duration: 0.8,
				stagger: 0.15,
				ease: 'power3.out'
			});

			gsap.from('.section-title', {
				scrollTrigger: {
					trigger: '.section-header',
					start: 'top 80%',
					once: true
				},
				opacity: 0,
				y: 40,
				duration: 0.8,
				ease: 'power3.out'
			});

			gsap.from('.section-eyebrow', {
				scrollTrigger: {
					trigger: '.section-header',
					start: 'top 80%',
					once: true
				},
				opacity: 0,
				y: 20,
				duration: 0.6,
				delay: 0.2,
				ease: 'power2.out'
			});

			gsap.from('.section-desc', {
				scrollTrigger: {
					trigger: '.section-header',
					start: 'top 80%',
					once: true
				},
				opacity: 0,
				y: 30,
				duration: 0.7,
				delay: 0.3,
				ease: 'power2.out'
			});

			gsap.from('.stat-card', {
				scrollTrigger: {
					trigger: '.stat-card',
					start: 'top 85%',
					once: true
				},
				y: 40,
				opacity: 0,
				duration: 0.7,
				stagger: 0.15,
				ease: 'power3.out'
			});

			gsap.from('.feature-item', {
				scrollTrigger: {
					trigger: '.feature-item',
					start: 'top 85%',
					once: true
				},
				x: -30,
